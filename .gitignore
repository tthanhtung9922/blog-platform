# ============================================================
# Nx
# ============================================================
.nx/cache
.nx/workspace-data
node_modules

# ============================================================
# .NET — Build artifacts
# ============================================================
**/bin/
**/obj/
/artifacts/
**/publish/
**/*.nupkg
**/*.snupkg

# .NET — IDE & user-specific files
*.user
*.suo
*.userprefs
*.DotSettings.user
.vs/
launchSettings.json

# .NET — Test results & coverage
**/TestResults/
**/coverage/
**/*.coveragexml
**/*.coverage
**/*.opencover.xml
**/*.cobertura.xml

# .NET — EF Core migration SQL output (generated by scripts/migration.sh)
migrations-output/
*.idempotent.sql

# .NET — User Secrets (never commit; use dotnet user-secrets)
**/secrets.json

# ============================================================
# Next.js / Node.js frontend
# ============================================================
.next/
out/
dist/
.turbo/

# ============================================================
# Nx workspace (workspace-data is runtime cache, not source)
# ============================================================
.nx/

# ============================================================
# Environment & secrets — NEVER commit these
# ============================================================
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
appsettings.*.local.json

# ============================================================
# Certificates & keys — NEVER commit these
# ============================================================
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer
secrets/

# ============================================================
# Docker — local data volumes (created by docker-compose)
# ============================================================
docker/data/
docker/postgres-data/
docker/redis-data/
docker/minio-data/

# ============================================================
# Kubernetes — generated secret manifests (use Sealed Secrets)
# ============================================================
deploy/k8s/**/*-secret.yaml
deploy/k8s/**/*-secrets.yaml

# ============================================================
# Testing — Playwright E2E
# ============================================================
playwright-report/
test-results/
blob-report/

# ============================================================
# Testing — k6 load test results
# ============================================================
tests/load/results/
tests/load/**/*.json
!tests/load/scenarios/**/*.json

# ============================================================
# Logs
# ============================================================
logs/
*.log

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# IDE
# ============================================================
.obsidian/
.idea/
*.swp
*.swo
